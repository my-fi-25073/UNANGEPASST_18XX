    "customKeycodes": [
        {
            "title": "Switch to the virtual desktop on the left. Sends Windows+Control+Left on Windows and Control+Left to move to the Space on the left on macOS.",
            "name": "Virtual Desktop Left",
            "shortName": "VD Left"
        },
        {
            "title": "Switch to the virtual desktop on the right. Sends Windows+Control+Right on Windows and Control+Right to move to the Space on the right on macOS.",
            "name": "Virtual Desktop Right",
            "shortName": "VD Right"
        },
        {
            "title": "Open the operating system overview. Sends Windows+Tab to open Task View on Windows and Control+Up to open Mission Control on macOS.",
            "name": "Task View / Mission Control",
            "shortName": "OS View"
        },
        {
            "title": "Move the text cursor one word to the left. Sends Ctrl+Left on Windows and Option+Left on macOS.",
            "name": "Word Left",
            "shortName": "Word L"
        },
        {
            "title": "Move the text cursor one word to the right. Sends Ctrl+Right on Windows and Option+Right on macOS.",
            "name": "Word Right",
            "shortName": "Word R"
        },
        {
            "title": "Switch the input language. Sends Right Alt on Windows and Control+Space on macOS.",
            "name": "Input Language",
            "shortName": "Lang"
        },
        {
            "title": "Open the system search launcher. Sends Windows+S to open Windows Search on Windows and Command+Space to open Spotlight on macOS.",
            "name": "System Search",
            "shortName": "Search"
        },
        {
            "title": "Take a full-screen screenshot. Sends Print Screen on Windows and Command+Shift+3 on macOS.",
            "name": "Full Screenshot",
            "shortName": "Full Cap"
        },
        {
            "title": "Capture a selected screen area. Sends Windows+Shift+S to open Snipping Tool capture on Windows and Command+Shift+4 on macOS.",
            "name": "Area Screenshot",
            "shortName": "Area Cap"
        },
        {
            "title": "Copy the selected file or folder path. Sends Ctrl+Shift+C on Windows and Command+Option+C on macOS Finder.",
            "name": "Copy File Path",
            "shortName": "Path"
        },
        {
            "title": "Open the emoji and symbol picker. Sends Windows+Period on Windows and Control+Command+Space on macOS.",
            "name": "Emoji",
            "shortName": "Emoji"
        },
        {
            "title": "Delete the selected file or item. Sends Delete on Windows and Command+Delete on macOS.",
            "name": "Delete Item",
            "shortName": "Delete"
        },
        {
            "title": "Rename the selected file or item. Sends F2 on Windows and Return on macOS.",
            "name": "Rename Item",
            "shortName": "Rename"
        },
        {
            "title": "Lock the current session. Sends Windows+L on Windows and Control+Command+Q on macOS.",
            "name": "Lock Screen",
            "shortName": "Lock"
        },
        {
            "title": "Switch to the next application. Sends Alt+Tab on Windows and Command+Tab on macOS.",
            "name": "App Switcher",
            "shortName": "App Sw"
        },
        {
            "title": "Hold the primary shortcut modifier for the current OS. Holds Left Control on Windows and Left Command on macOS.",
            "name": "Command / Ctrl",
            "shortName": "Cmd/Ctrl"
        },
        {
            "title": "Hold the secondary system modifier for the current OS. Holds the Windows key on Windows and Left Control on macOS.",
            "name": "Windows / Control",
            "shortName": "Win/Ctrl"
        }
    ]
}
